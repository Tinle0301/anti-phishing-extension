{
  "manifest_version": 3,
  "name": "Anti-Phishing Login Detector",
  "version": "1.0.0",
  "description": "Warns users about suspicious login and AiTM-style phishing pages.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "detector.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Anti-Phishing Detector"
  }
}